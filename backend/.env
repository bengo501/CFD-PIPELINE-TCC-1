# configuracoes do banco de dados
# em desenvolvimento local, usar sqlite para evitar dependencias extras
DATABASE_URL=sqlite:///./cfd_pipeline.db

# para usar com docker compose + postgresql, descomente a linha abaixo
# e comente a linha de sqlite acima:
# DATABASE_URL=postgresql://cfd_user:cfd_password@postgres:5432/cfd_pipeline

# configuracoes alternativas (apenas para postgres)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=cfd_user
# DB_PASSWORD=cfd_password
# DB_NAME=cfd_pipeline

